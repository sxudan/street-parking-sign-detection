# Copy to .env (or wire into EAS secrets / app config).

# Where the parking-detector FastAPI backend is reachable from the device.
# - iOS simulator can use http://localhost:8000
# - Android emulator must use http://10.0.2.2:8000
# - Physical device needs your laptop's LAN IP (e.g. http://192.168.1.10:8000)
EXPO_PUBLIC_API_BASE_URL=http://localhost:8000

# Melbourne open data is keyless; nothing to set.
